# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Core
DEBUG=true
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=*

# Database --------------------------------------------------------------
# Leave USE_RDS=false to use the self-contained local SQLite database (default).
# Set USE_RDS=true to connect to the managed PostgreSQL instance instead and
# provide the credentials below (do NOT hard-code them in settings.py).
USE_RDS=false
DB_NAME=postgres
DB_USER=db_username
DB_PASSWORD=
DB_HOST=
DB_PORT=5432

# Email -----------------------------------------------------------------
# Console backend prints emails to the server log (no SMTP needed).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For real SMTP, switch the backend and fill these in:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=false
DEFAULT_FROM_EMAIL=Coffee Shop <no-reply@coffeeshop.demo>
